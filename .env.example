# Astro-Oracle Environment Variables

# API Keys (Provide at least one)
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key

# Application Settings
APP_NAME=Astro-Oracle
DEBUG=True
PORT=8000

# Vector Database
CHROMA_DB_DIRECTORY=./app/vectorstore
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Astrology Engine Preferences
DEFAULT_LANGUAGE=tr
MAPPING_SYSTEM=placidus
ASTROLOGY_PERSPECTIVE=combination  # western, vedic, helenistic, combination
